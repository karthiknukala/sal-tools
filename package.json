{
  "name": "sal-tools",
  "displayName": "SAL Tools",
  "description": "Minimal SAL syntax highlighting and GitHub release installer.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:helloWorld.hello",
    "onCommand:sal.installFromGitHubRelease"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sal",
        "aliases": [
          "SAL",
          "sal"
        ],
        "extensions": [
          ".sal"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sal",
        "scopeName": "source.sal",
        "path": "./syntaxes/sal.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "helloWorld.hello",
        "title": "Hello World: Say Hello"
      },
      {
        "command": "sal.installFromGitHubRelease",
        "title": "SAL: Install from GitHub Release"
      }
    ],
    "configuration": {
      "title": "SAL",
      "properties": {
        "sal.toolchain.binPath": {
          "type": "string",
          "default": "",
          "description": "Directory containing installed SAL executables."
        },
        "sal.install.repository": {
          "type": "string",
          "default": "karthiknukala/sal",
          "description": "GitHub repository to install from, written as owner/repo."
        },
        "sal.install.releaseTag": {
          "type": "string",
          "default": "nightly",
          "description": "Release tag to install. Leave empty to install the latest release."
        },
        "sal.install.directory": {
          "type": "string",
          "default": "",
          "description": "Install directory. Leave empty to use VS Code extension storage."
        }
      }
    }
  }
}
