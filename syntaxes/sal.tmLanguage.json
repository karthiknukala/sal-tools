{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SAL",
  "scopeName": "source.sal",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.sal",
          "match": "--.*$"
        },
        {
          "name": "comment.block.sal",
          "begin": "%\\{",
          "end": "\\}%"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sal",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sal",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "name": "meta.context.sal",
          "match": "\\b([A-Za-z_][A-Za-z0-9_']*)\\b\\s*(?=\\{?[^:=]*\\}?\\s*:\\s*CONTEXT\\b)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.sal"
            }
          }
        },
        {
          "name": "meta.module.sal",
          "match": "\\b([A-Za-z_][A-Za-z0-9_']*)\\b\\s*(?=\\{?[^:=]*\\}?\\s*:\\s*MODULE\\b)",
          "captures": {
            "1": {
              "name": "entity.name.type.module.sal"
            }
          }
        },
        {
          "name": "meta.assertion.sal",
          "match": "\\b([A-Za-z_][A-Za-z0-9_']*)\\b\\s*(?=:\\s*(?:THEOREM|LEMMA|CLAIM|OBLIGATION)\\b)",
          "captures": {
            "1": {
              "name": "entity.name.function.sal"
            }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.sal",
          "match": "\\b(?:ARRAY|BOOLEAN|CONTEXT|DATATYPE|GLOBAL|INPUT|INTEGER|LOCAL|MODULE|NATURAL|OUTPUT|REAL|TYPE)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sal",
          "match": "\\b(?:BEGIN|CASE|DEFAULT|ELSE|ELSIF|END|ENDIF|IF|OF|THEN|WITH)\\b"
        },
        {
          "name": "keyword.other.sal",
          "match": "\\b(?:ASSERTION|AXIOM|CLAIM|DEFINITION|EXISTS|FORALL|INITIALIZATION|INVARIANT|LEMMA|LET|OBLIGATION|THEOREM|TRANSITION)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sal",
          "match": "\\b(?:FALSE|TRUE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sal",
          "match": "(?:=>|->|/=|<=|>=|\\b(?:AND|OR|NOT|XOR|IMPLIES|IFF|IN)\\b|[=:+\\-*/<>])"
        }
      ]
    }
  }
}
