{
  "name": "SAL",
  "scopeName": "source.sal",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.percentage.sal",
          "match": "%.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sal",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sal",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sal",
          "match": "<=>|=>|/="
        },
        {
          "name": "keyword.operator.sal",
          "match": "-->|\\|-|\\.{2}|:=|="
        },
        {
          "name": "keyword.operator.sal",
          "match": "\\+|-|\\*|/|<|<=|>|>=|\\^"
        },
        {
          "name": "punctuation.separator.qualification.sal",
          "match": "!"
        },
        {
          "name": "punctuation.definition.prime.sal",
          "match": "'"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.sal",
          "match": "\\b(?i:NZINTEGER|BOOLEAN|INTEGER|NATURAL|NZREAL|REAL)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.sal",
          "match": "\\b(?i:FALSE|TRUE)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sal",
          "match": "\\b(?i:INITIALIZATION|DEFINITION|OBLIGATION|DATATYPE|CONTEXT|THEOREM|EXISTS|FORALL|GLOBAL|LAMBDA|MODULE|OUTPUT|RENAME|BEGIN|ELSIF|ENDIF|INPUT|LEMMA|LOCAL|CLAIM|ARRAY|ELSE|THEN|TYPE|WITH|END|LET|IF|IN|TO|OF)\\b"
        },
        {
          "name": "keyword.operator.word.sal",
          "match": "\\b(?i:AND|NOT|XOR|OR)\\b"
        },
        {
          "name": "support.function.temporal.sal",
          "match": "\\b(?i:AG|AF|AX|EG|EF|EX|AU|EU|G|F|X|U|R)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.context.sal",
          "match": "^\\s*([A-Za-z][\\w\\?_]*)(\\s*\\{[^}]*\\})?\\s*:\\s*\\b(?i:CONTEXT)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.context.sal"
            },
            "2": {
              "name": "meta.parameters.context.sal"
            }
          }
        },
        {
          "name": "meta.declaration.module.sal",
          "match": "^\\s*([A-Za-z][\\w\\?_]*)(\\s*\\[[^\\]]*\\])?\\s*:\\s*\\b(?i:MODULE)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.module.sal"
            },
            "2": {
              "name": "meta.parameters.module.sal"
            }
          }
        },
        {
          "name": "meta.declaration.type.sal",
          "match": "^\\s*([A-Za-z][\\w\\?_]*)\\s*:\\s*\\b(?i:TYPE)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.sal"
            }
          }
        },
        {
          "name": "meta.declaration.assertion.sal",
          "match": "^\\s*([A-Za-z][\\w\\?_]*)\\s*:\\s*\\b(?i:THEOREM|LEMMA|CLAIM|OBLIGATION)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.assertion.sal"
            }
          }
        },
        {
          "name": "meta.declaration.label.sal",
          "match": "^\\s*([A-Za-z][\\w\\?_]*)\\s*:\\s*$",
          "captures": {
            "1": {
              "name": "entity.name.label.sal"
            }
          }
        }
      ]
    }
  }
}