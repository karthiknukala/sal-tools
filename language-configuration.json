{
  "comments": {
    "lineComment": "%"
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "[#",
      "#]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "[#",
      "close": "#]"
    }
  ],
  "surroundingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "[#",
      "close": "#]"
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "(?i)^.*\\b(begin|then|else|elsif|transition|initialization)\\b.*$",
    "decreaseIndentPattern": "(?i)^\\s*\\b(end|endif)\\b.*$"
  },
  "folding": {
    "markers": {
      "start": "(?i)^\\s*begin\\b",
      "end": "(?i)^\\s*end\\b"
    }
  }
}